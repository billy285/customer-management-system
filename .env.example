# Required: update these values before production deploy
GHCR_OWNER=YOUR_GH_USERNAME
IMAGE_TAG=latest
APP_IMAGE=ghcr.io/${GHCR_OWNER}/customer-management-system:${IMAGE_TAG}

# Optional: HTTPS reverse proxy (Caddy)
ENABLE_HTTPS=false
DOMAIN=crm.example.com
TLS_EMAIL=admin@example.com

# Host ports
APP_PORT=8080
HTTP_PORT=80
HTTPS_PORT=443
